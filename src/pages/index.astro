---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const projects = await getCollection('projects');
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mahyar Arani | Portfolio</title>
	</head>
	<body class="bg-gray-900 text-gray-100 font-sans">
		<main class="max-w-6xl mx-auto px-4 py-20">
			<header class="mb-16">
				<h1 class="text-5xl font-extrabold mb-4 bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">
					Mahyar Arani
				</h1>
				<p class="text-xl text-gray-400 max-w-2xl">
					Data Scientist & Automation Expert specializing in AI, Power Platform, and Business Intelligence.
				</p>
			</header>

			<section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{projects.map((project) => (
					<a href={`/projects/${project.data.slug}`} class="group block bg-gray-800 rounded-2xl overflow-hidden border border-gray-700 hover:border-blue-500 transition-all duration-300 transform hover:-translate-y-2">
						<div class="h-48 overflow-hidden bg-gray-700 flex items-center justify-center">
							{project.data.images && project.data.images.length > 0 ? (
								<img 
									src={`/images/${project.data.images[0]}`} 
									alt={project.data.title}
									class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
								/>
							) : (
								<div class="text-gray-500 italic">No Preview</div>
							)}
						</div>
						<div class="p-6">
							<h2 class="text-xl font-bold mb-2 group-hover:text-blue-400 transition-colors">
								{project.data.title}
							</h2>
							<p class="text-gray-400 text-sm line-clamp-3">
								Click to view details and findings.
							</p>
						</div>
					</a>
				))}
			</section>
		</main>
	</body>
</html>
