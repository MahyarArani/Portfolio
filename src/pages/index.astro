---
import { getCollection } from 'astro:content';
import EntryListItem from '../components/EntryListItem.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getFeatured, isProject, isResearch, siteMeta, sortEntries } from '../lib/site';
import { about } from '../lib/about';

const entries = sortEntries(await getCollection('projects'));
const projectEntries = entries.filter(isProject);
const researchEntries = entries.filter(isResearch);
const featured = getFeatured(entries);
const base = import.meta.env.BASE_URL;
---

<SiteLayout title={`${siteMeta.name} | Portfolio`}>

  <!-- ─── Personal intro ─────────────────────────────────────────────────── -->
  <section class="intro-section">
    <div class="shell intro-inner">

      <div class="intro-text">
        <span class="eyebrow">Portfolio</span>
        <h1 class="intro-name">{about.greeting}</h1>
        <p class="intro-role">{about.role}</p>
        <p class="intro-bio">{about.bio}</p>
        <div class="pill-row">
          {about.skills.map((skill) => <span class="skill-chip">{skill}</span>)}
        </div>
        <div class="intro-actions">
          <a href={`${base}projects/`} class="button-link">View Projects</a>
          <a href={`${base}about/`} class="button-link-muted">About Me</a>
          <a href={`mailto:${about.email}`} class="button-link-muted">Contact</a>
        </div>
      </div>

      <div class="intro-card">
        <div class="intro-card-header">
          <div class="intro-avatar">{about.name.split(' ').map((n: string) => n[0]).join('')}</div>
          <div>
            <strong class="intro-card-name">{about.name}</strong>
            <span class="intro-card-sub">Data Science &amp; Research</span>
          </div>
        </div>

        <div class="intro-stats">
          <div class="intro-stat">
            <strong>{projectEntries.length}</strong>
            <span>Projects</span>
          </div>
          <div class="intro-stat">
            <strong>{researchEntries.length}</strong>
            <span>Papers</span>
          </div>
          <div class="intro-stat">
            <strong>4</strong>
            <span>Domains</span>
          </div>
        </div>

        <div class="intro-focus">
          {about.focusAreas.map((area) => (
            <div class="intro-focus-item">
              <strong>{area.title}</strong>
              <span>{area.desc}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ─── Selected Projects ────────────────────────────────────────────────── -->
  <section class="section">
    <div class="shell section-head">
      <div>
        <span class="eyebrow">Work</span>
        <h2 class="section-title">Selected projects</h2>
      </div>
      <a href={`${base}projects/`} class="button-link-muted">See all →</a>
    </div>
    <div class="shell entry-list">
      {featured.map((entry) => <EntryListItem entry={entry} />)}
    </div>
  </section>

  <!-- ─── Research ─────────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="shell section-head">
      <div>
        <span class="eyebrow">Research</span>
        <h2 class="section-title">Publications &amp; analytical work</h2>
      </div>
      <a href={`${base}research/`} class="button-link-muted">All research →</a>
    </div>
    <div class="shell entry-list">
      {researchEntries.slice(0, 3).map((entry) => <EntryListItem entry={entry} />)}
    </div>
  </section>

</SiteLayout>
