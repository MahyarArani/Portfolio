---
import { getCollection } from 'astro:content';
import EntryListItem from '../../components/EntryListItem.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { isResearch, siteMeta, sortEntries } from '../../lib/site';

const entries = sortEntries((await getCollection('projects')).filter(isResearch));
const base = import.meta.env.BASE_URL;
---

<SiteLayout title={`Research | ${siteMeta.name}`}>
  <section class="page-hero">
    <div class="shell">
      <span class="eyebrow">Research</span>
      <h1 class="page-title">Publications, papers, and ongoing studies.</h1>
      <p class="lede">
        This section brings together publication-oriented work across organizational studies, sustainability,
        consumer behavior, and related analytical topics.
      </p>
    </div>
  </section>

  <section class="section section-tight">
    <div class="shell collection-banner">
      <div>
        <span class="eyebrow">Research Archive</span>
        <h2>{entries.length} research entries</h2>
      </div>
      <p>
        Publication-oriented work across organizational studies, sustainability, consumer behavior, and analytical methods.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="shell quote-band" style="margin-bottom: 1.25rem;">
      <p>
        The research portfolio complements the applied project work by showing academic writing, structured evaluation
        methods, and long-form analysis beyond operational delivery.
      </p>
    </div>

    <div class="shell entry-list">
      {entries.map((entry) => <EntryListItem entry={entry} />)}
    </div>

    <div class="shell" style="margin-top: 1.25rem;">
      <div class="mosaic-card">
        <img src={`${base}google-sites/images/Papers/deecf8d3a0ef17ae1fb752e12112e0eb.jpg`} alt="Research section visual" />
        <div class="mosaic-caption">
          <strong>Research archive</strong>
          <span>Papers, frameworks, and publication-oriented studies across multiple domains.</span>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
