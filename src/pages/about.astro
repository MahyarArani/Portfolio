---
import SiteLayout from '../layouts/SiteLayout.astro';
import { siteMeta } from '../lib/site';

const base = import.meta.env.BASE_URL;
---

<SiteLayout title={`About | ${siteMeta.name}`}>
  <section class="page-hero">
    <div class="shell about-hero-grid">
      <div>
        <span class="eyebrow">About</span>
        <h1 class="page-title">Building operational systems from complex data problems.</h1>
        <p class="lede">
          Mahyar Arani works across applied analytics, automation, geospatial systems, business intelligence, and research.
          The work combines technical implementation with decision support, turning raw data and fragmented workflows into
          usable tools for teams and stakeholders.
        </p>
        <div class="hero-actions">
          <a href={`${base}projects/`} class="button-link">View Projects</a>
          <a href={`${base}research/`} class="button-link-muted">View Research</a>
        </div>
      </div>

      <aside class="profile-panel">
        <span class="eyebrow">Profile Snapshot</span>
        <h3>Applied analytics, delivery, and research</h3>
        <div class="profile-facts">
          <div class="profile-fact">
            <strong>Focus</strong>
            <span>AI workflows, Power Platform, GIS, BI, and analytical research.</span>
          </div>
          <div class="profile-fact">
            <strong>Working style</strong>
            <span>Problem framing, technical implementation, validation, and stakeholder-facing reporting.</span>
          </div>
          <div class="profile-fact">
            <strong>Contact</strong>
            <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell mosaic-grid">
      <div class="mosaic-card">
        <img src={`${base}google-sites/images/About/6cdf7efe64b19032e5a0831a488d00d9.jpg`} alt="About page visual" />
        <div class="mosaic-caption">
          <strong>Applied problem solving</strong>
          <span>Automation, dashboarding, cloud workflows, and decision support.</span>
        </div>
      </div>
      <div class="mosaic-stack">
        <div class="mosaic-card">
          <img src={`${base}google-sites/images/About/39b511dacf577b7d8d65710d8ac5432c.jpg`} alt="Research and analytics visual" />
          <div class="mosaic-caption">
            <strong>Research mindset</strong>
            <span>Academic work informs the way operational systems are designed and evaluated.</span>
          </div>
        </div>
        <div class="mosaic-card">
          <img src={`${base}google-sites/images/About/e7f160a2f8ed3114741686f388a1cf5f.jpg`} alt="Portfolio background visual" />
          <div class="mosaic-caption">
            <strong>Cross-functional delivery</strong>
            <span>From data cleaning and modeling to deployment and stakeholder reporting.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split-grid">
      <div class="story-card">
        <span class="eyebrow">Profile</span>
        <h3>Professional focus</h3>
        <p>
          This work sits at the intersection of data science and delivery. Across the portfolio, the recurring pattern is
          translating messy operational or research problems into structured systems. That includes OCR pipelines,
          Power Platform workflows, Power BI governance, geospatial routing, machine learning comparisons, and NLP analysis.
        </p>
        <p>
          The emphasis is not only on analysis, but on implementation: building workflows, validating outputs, supporting
          stakeholders, and presenting results in forms teams can actually use.
        </p>
      </div>

      <div class="story-card">
        <span class="eyebrow">Capabilities</span>
        <h3>Core strengths</h3>
        <ul>
          <li>Operational workflow design using Azure, Power Platform, and automation tools.</li>
          <li>Business intelligence reporting with strong attention to data quality and exception handling.</li>
          <li>Geospatial analysis and routing-oriented problem solving using ArcGIS and related systems.</li>
          <li>Research-driven thinking across organizational agility, sustainability, and consumer behavior.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell capability-grid">
      <div class="surface">
        <span class="eyebrow">Applied Work</span>
        <h3>Delivery-oriented portfolio</h3>
        <p>
          The project work focuses on practical implementation: automation pipelines, map-based analysis, reporting systems,
          classification workflows, and technical solutions designed for real operational use.
        </p>
      </div>
      <div class="surface">
        <span class="eyebrow">Research</span>
        <h3>Analytical depth</h3>
        <p>
          The research portfolio adds another layer to the profile, showing structured inquiry into organizational behavior,
          sustainability, supply chains, and digital consumer behavior.
        </p>
      </div>
      <div class="surface">
        <span class="eyebrow">Collaboration</span>
        <h3>Working across teams</h3>
        <p>
          Many of the projects reflect collaboration with operations teams, GIS specialists, management stakeholders, and
          business users who needed reliable outputs rather than isolated technical experiments.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell quote-band">
      <span class="eyebrow">Contact</span>
      <p>
        For project discussions, research conversations, or collaboration opportunities, the best contact point is
        <a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>.
      </p>
    </div>
  </section>
</SiteLayout>
