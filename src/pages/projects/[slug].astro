---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCoverImage, getExcerpt, isResearch } from '../../lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;
const cover = getCoverImage(project);
const entryType = isResearch(project) ? 'Research' : 'Project';
---

<SiteLayout title={`${project.data.title} | Mahyar Arani`} description={getExcerpt(project)}>
  <section class="page-hero">
    <div class="shell">
      <div class="eyebrow-row" style="margin-bottom: 0.75rem;">
        <span class="eyebrow-tag">{entryType}</span>
        <a href={isResearch(project) ? `${base}research/` : `${base}projects/`} class="button-link-muted">Back</a>
      </div>
      <h1 class="page-title">{project.data.title}</h1>
      {project.data.date && <p class="lede">Date: {project.data.date}</p>}
    </div>
  </section>

  <section class="section">
    <div class="shell split-grid">
      <div class="surface">
        <p>{getExcerpt(project)}</p>
      </div>
      <div class="surface">
        <div class="pill-row">
          <span class="metric-chip">{entryType}</span>
          {project.data.images && <span class="metric-chip">{project.data.images.length} visuals</span>}
          {project.data.date && <span class="metric-chip">{project.data.date.slice(0, 4)}</span>}
        </div>
      </div>
    </div>
  </section>

  {cover && (
    <section class="section">
      <div class="shell mosaic-card">
        <img src={cover} alt={project.data.title} />
        <div class="mosaic-caption">
          <strong>{project.data.title}</strong>
          <span>{entryType} overview</span>
        </div>
      </div>
    </section>
  )}

  {project.data.images && project.data.images.length > 1 && (
    <section class="section">
      <div class="shell card-grid">
        {project.data.images.slice(1, 4).map((img) => (
          <div class="mosaic-card">
            <img src={`${base}google-sites/images/${img}`} alt={project.data.title} loading="lazy" />
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <div class="shell surface">
      <article class="prose prose-invert prose-lg max-w-none prose-headings:font-normal prose-headings:text-white prose-p:text-slate-300 prose-li:text-slate-300 prose-strong:text-white prose-a:text-emerald-300">
        <Content />
      </article>
    </div>
  </section>
</SiteLayout>
