---
import type { CollectionEntry } from 'astro:content';
import { getCoverImage, getExcerpt, getLabel, getYear } from '../lib/site';

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const base = import.meta.env.BASE_URL;
const cover = getCoverImage(entry);
---

<article class="entry-row">
  <a href={`${base}projects/${entry.data.slug}`} class="entry-row-link">
    <div class="entry-row-media">
      {cover ? (
        <img src={cover} alt={entry.data.title} loading="lazy" class="entry-row-image" />
      ) : (
        <div class="entry-row-fallback">No preview</div>
      )}
    </div>
    <div class="entry-row-content">
      <div class="entry-row-meta">
        <span class="eyebrow-tag">{getLabel(entry)}</span>
        <span class="entry-row-year">{getYear(entry)}</span>
      </div>
      <h3>{entry.data.title}</h3>
      <p>{getExcerpt(entry)}</p>
    </div>
  </a>
</article>
